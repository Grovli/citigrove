# citigrove-store-api — environment template. Copy to .env for local dev.
# Every var is the UPPER_CASE of a Settings field (pydantic case-insensitive).
# Secrets are blank here; in Cloud Run they come from Secret Manager.

# ── App ─────────────────────────────────────────────────────────────
APP_ENV=development
SERVICE_NAME=citigrove-store-api

# ── MongoDB ─────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/citigrove
MONGO_DB=citigrove

# ── Redis (idempotency / dedup; optional in v1) ────────────────────
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Auth0 ───────────────────────────────────────────────────────────
AUTH0_DOMAIN=dev-rw8ff6vxgb7t0i4c.us.auth0.com
AUTH0_AUDIENCE=https://grovli.citigrove.com/audience

# ── Admin gating (email-claim domain check; comma-list supported) ───
ALLOWED_ADMIN_DOMAIN=citigrove.com

# ── Internal services: Grovli Payments (Grovli Direct) ──────────────
PAYMENTS_BASE_URL=https://grovli-payments-uyply7jkca-uc.a.run.app
# fail-closed: empty -> payments_client returns 503 instead of calling anon.
PAYMENTS_INTERNAL_KEY=
PAYMENTS_USE_OIDC=true
# empty -> audience defaults to PAYMENTS_BASE_URL.
PAYMENTS_OIDC_AUDIENCE=

# ── Stripe (Tax calc + webhook verify only; NOT PaymentIntents) ─────
STRIPE_SECRET_KEY=
# empty in production -> POST /webhook/stripe returns 503 (fail-closed).
STRIPE_WEBHOOK_SECRET=
# false -> tax_cents=0 graceful-degrade (DEV ONLY; prod fails closed).
STRIPE_TAX_ENABLED=true

# ── Shippo (live rates + label + tracking) ──────────────────────────
SHIPPO_API_TOKEN=
# empty in production -> POST /webhook/shippo returns 503 (fail-closed).
SHIPPO_WEBHOOK_SECRET=
SHIP_FROM_NAME=CitiGrove
SHIP_FROM_STREET1=
SHIP_FROM_CITY=
SHIP_FROM_STATE=
SHIP_FROM_ZIP=
SHIP_FROM_COUNTRY=US

# ── APNs (24h RSVP reminder; enqueue is a stub in v1) ───────────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.citigrove.app
APNS_AUTH_KEY_BASE64=
APNS_USE_SANDBOX=true

# ── Cloud Tasks (RSVP reminder enqueue) ─────────────────────────────
GCP_PROJECT_ID=organic-spirit-488116-e2
CLOUD_TASKS_LOCATION=us-central1
# empty -> enqueue stub no-ops + WARN.
TASK_INVOKER_SA_EMAIL=
CLOUD_TASKS_TARGET_BASE=
RSVP_REMINDER_QUEUE=citigrove-tasks-rsvp-reminders

# ── Observability (OTel) ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=citigrove-store-api
OTEL_RESOURCE_ATTRIBUTES=

# ── GCP / region ────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=organic-spirit-488116-e2
GCP_REGION=us-central1
