{
  "hosting": {
    "target": "site",
    "public": "out",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": ["firebase.json", "**/.DS_Store", "**/node_modules/**"],
    "headers": [
      {
        "source": "/_next/static/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/.well-known/apple-app-site-association",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|avif|ico|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/media",
        "function": "citigroveMedia",
        "region": "us-east1"
      },
      {
        "source": "/api/subscribe",
        "function": "citigroveSubscribe",
        "region": "us-east1"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "citigrove",
      "ignore": ["node_modules", ".git"]
    }
  ]
}
